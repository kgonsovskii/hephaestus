{
  "DomainHost": {
    "WebRoot": "web",
    "WebRootSearchMaxAscents": 10,
    "DomainsFileName": "domains.json",
    "RefreshSeconds": 30,
    "CertDirectoryName": "cert",
    "CertPfxFileName": "hephaestus.pfx",
    "HttpsPort": 5443
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
