<Project Sdk="Microsoft.NET.Sdk.Web">

  <!-- Class library: MVC + Razor views; hosted by DomainHost at /cp via cp.CpWebExtensions -->
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <GenerateProgramFile>false</GenerateProgramFile>
    <RootNamespace>cp</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SMBLibrary" Version="$(PkgSMBLibraryVersion)" />
    <PackageReference Include="Npgsql" Version="$(PkgNpgsqlVersion)" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Web.config">
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </None>
    <None Update="Readme\GetVbs.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="php\GetVbs.txt">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="publish.ps1">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Domain\Domain.csproj" />
    <ProjectReference Include="..\model\model.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Update="Views\Shared\_TabContent.cshtml">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
    <Content Update="Views\Shared\BuxViewComponent">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="Views\Manage\index.cshtml" />
    <AdditionalFiles Include="Views\Shared\Components\Pack\Default.cshtml" />
  </ItemGroup>

  <ItemGroup>
    <_ContentIncludedByDefault Remove="bin\Debug\net9.0\Nuget.config" />
    <_ContentIncludedByDefault Remove="bin\Debug\net9.0\Web.config" />
    <_ContentIncludedByDefault Remove="bin\Release\net10.0\Nuget.config" />
    <_ContentIncludedByDefault Remove="bin\Release\net10.0\Web.config" />
    <_ContentIncludedByDefault Remove="bin\Debug\net9.0\appsettings.Development.json" />
    <_ContentIncludedByDefault Remove="bin\Debug\net9.0\appsettings.json" />
    <_ContentIncludedByDefault Remove="bin\Debug\net9.0\cp.deps.json" />
    <_ContentIncludedByDefault Remove="bin\Debug\net9.0\cp.runtimeconfig.json" />
    <_ContentIncludedByDefault Remove="bin\Debug\net9.0\cp.staticwebassets.endpoints.json" />
    <_ContentIncludedByDefault Remove="bin\Release\net10.0\appsettings.Development.json" />
    <_ContentIncludedByDefault Remove="bin\Release\net10.0\appsettings.json" />
    <_ContentIncludedByDefault Remove="bin\Release\net10.0\cp.deps.json" />
    <_ContentIncludedByDefault Remove="bin\Release\net10.0\cp.runtimeconfig.json" />
    <_ContentIncludedByDefault Remove="bin\Release\net10.0\cp.staticwebassets.endpoints.json" />
    <_ContentIncludedByDefault Remove="bin\Debug\net9.0\Views\Shared\_TabContent.cshtml" />
    <_ContentIncludedByDefault Remove="bin\Release\net10.0\Views\Shared\_TabContent.cshtml" />
    <_ContentIncludedByDefault Remove="_buildobj\Domain.csproj.nuget.dgspec.json" />
    <_ContentIncludedByDefault Remove="_buildobj\project.assets.json" />
    <_ContentIncludedByDefault Remove="_buildobj\Release\Commons.sourcelink.json" />
  </ItemGroup>

</Project>
