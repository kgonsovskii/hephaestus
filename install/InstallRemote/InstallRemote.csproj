<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>install-remote</AssemblyName>
    <RootNamespace>InstallRemote</RootNamespace>
    <RollForward>LatestPatch</RollForward>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\InstallRemote.Core\InstallRemote.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="..\shared\install-remote.txt" CopyToOutputDirectory="PreserveNewest" Link="install-remote.txt" />
    <Content Include="..\shared\wait.sh" CopyToOutputDirectory="PreserveNewest" Link="wait.sh" />
    <Content Include="..\shared\install-remote-creds.txt" CopyToOutputDirectory="PreserveNewest" Link="install-remote-creds.txt" />
  </ItemGroup>
</Project>
