<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>install-remote</AssemblyName>
    <RootNamespace>InstallRemote</RootNamespace>
    <RollForward>LatestPatch</RollForward>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="..\install-remote.txt" CopyToOutputDirectory="PreserveNewest" Link="install-remote.txt" />
  </ItemGroup>
</Project>
