{
  "ConnectionStrings": {
    "Default": "Host=127.0.0.1;Port=5432;Database=hephaestus;Username=tss;Password=123"
  },
  "Refiner": {
    "StatsInterval": "00:01:00",
    "DomainInterval": "00:01:00",
    "TroyanInterval": "00:30:00"
  },
  "Technitium": {
    "Enabled": true,
    "BaseUrl": "http://127.0.0.1:5380",
    "User": "admin",
    "Password": "123",
    "ForwarderEnabled": true,
    "Forwarders": "8.8.8.8",
    "Recursion": "Allow",
    "DnssecEnabled": true,
    "PtrEnabled": true
  },
  "DomainHost": {
    "HephaestusDataDirectoryName": "data",
    "WebRoot": "web",
    "WebRootSearchMaxAscents": 10,
    "DomainsFileName": "domains.json",
    "DomainsIgnoreFileName": "domains-ignore.json",
    "RefreshSeconds": 30,
    "CertDirectoryName": "cert",
    "CertPublicCerFileName": "hephaestus-trusted-root.cer",
    "CertPfxFileName": "hephaestus.pfx",
    "CertPfxPassword": "123",
    "HttpPort": 80,
    "HttpsPort": 443,
    "StaticFileCacheMaxAgeSeconds": 120,
    "RepositoryMarkerFileName": "defaulticon.ico",
    "RepositoryRootSearchMaxAscents": 50
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
