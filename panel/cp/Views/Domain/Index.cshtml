@using Domain
@model cp.Models.DomainPageViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Domains</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
<header class="container mt-2">
    @await Html.PartialAsync("_LogoutButton")
</header>
<div class="container mt-4 mb-5">
    <p><a href="@Url.Action("Index", "Cp")">← Control panel</a></p>
    <h1>Domains</h1>
    <p class="text-muted small">
        Edits <code>domains.json</code> in the Hephaestus data root. Static files resolve in order:
        <code>web/sites/{hostname}/</code> first, then <code>web/classes/{class}/</code>
        (empty class uses <code>analytics</code>). Folders under <code>web/classes</code> drive the class list below.
    </p>

    @if (Model.Message != null)
    {
        <div class="alert alert-success" role="alert">@Model.Message</div>
    }

    <div class="card mb-4">
        <div class="card-header"><strong>Bulk add</strong></div>
        <div class="card-body">
            <form method="post" action="@Url.Action("Bulk", "Domain")">
                <div class="row g-2 align-items-start flex-column flex-md-row">
                    <div class="col" style="min-width: 0;">
                        <label class="form-label mb-1">Hostnames (one per line)</label>
                        <textarea name="bulkDomainLines" class="form-control font-monospace" rows="6" placeholder="host1.example.com&#10;host2.example.com"></textarea>
                    </div>
                    <div class="col-12 col-md-auto d-flex flex-column gap-2" style="width: 13rem; max-width: 100%;">
                        <div>
                            <label class="form-label mb-1" for="bulkClassSelect">Class</label>
                            <select id="bulkClassSelect" name="bulkClass" class="form-select" title="Class for all new rows">
                                <option value="">(default → analytics)</option>
                                @foreach (var c in Model.ClassFolderNames)
                                {
                                    var sel = string.Equals(c, WebSiteLayout.DefaultDomainClassFolderName, StringComparison.OrdinalIgnoreCase);
                                    <option value="@c" @(sel ? "selected" : null)>@c</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-secondary w-100">Add domains</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><strong>Edit domains</strong></div>
        <div class="card-body">
            <form method="post" action="@Url.Action("Save", "Domain")">
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Enabled</th>
                                <th>Domain</th>
                                <th>IP</th>
                                <th>Class</th>
                                <th>Content</th>
                                <th>Redirect URL</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="domainRowsContainer">
                        @for (var i = 0; i < Model.DomainRows.Count; i++)
                        {
                            var r = Model.DomainRows[i];
                            <tr class="domain-edit-row">
                                <td>
                                    <select name="DomainRows[@i].Enabled" class="form-select form-select-sm" style="min-width: 4.5rem;" aria-label="Enabled">
                                        <option value="true" @(r.Enabled ? "selected" : null)>On</option>
                                        <option value="false" @(!r.Enabled ? "selected" : null)>Off</option>
                                    </select>
                                </td>
                                <td><input type="text" name="DomainRows[@i].Domain" value="@r.Domain" class="form-control form-control-sm" placeholder="host.example.com"/></td>
                                <td><input type="text" name="DomainRows[@i].Ip" value="@r.Ip" class="form-control form-control-sm" placeholder="optional"/></td>
                                <td>
                                    <select name="DomainRows[@i].DomainClass" class="form-select form-select-sm">
                                        <option value="" @(string.IsNullOrWhiteSpace(r.DomainClass) ? "selected" : null)>(default → analytics)</option>
                                        @foreach (var c in Model.ClassFolderNames)
                                        {
                                            <option value="@c" @(string.Equals(r.DomainClass, c, StringComparison.OrdinalIgnoreCase) ? "selected" : null)>@c</option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <select name="DomainRows[@i].ContentKind" class="form-select form-select-sm">
                                        <option value="javascript" @(r.ContentKind.Equals("javascript", StringComparison.OrdinalIgnoreCase) ? "selected" : null)>JavaScript</option>
                                        <option value="html" @(r.ContentKind.Equals("html", StringComparison.OrdinalIgnoreCase) ? "selected" : null)>HTML</option>
                                        <option value="redirect" @(r.ContentKind.Equals("redirect", StringComparison.OrdinalIgnoreCase) ? "selected" : null)>Redirect</option>
                                    </select>
                                </td>
                                <td><input type="text" name="DomainRows[@i].RedirectUrl" value="@r.RedirectUrl" class="form-control form-control-sm" placeholder="if redirect"/></td>
                                <td><button type="button" class="btn btn-outline-danger btn-sm" onclick="removeDomainRow(this)">Remove</button></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
                <button type="button" class="btn btn-secondary btn-sm mt-2" onclick="addDomainRow()">Add row</button>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Save domains</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const domainClassNames = @Html.Raw(Json.Serialize(Model.ClassFolderNames));
    const defaultClassName = @Html.Raw(Json.Serialize(WebSiteLayout.DefaultDomainClassFolderName));
    let domainRowIndex = @Model.DomainRows.Count;

    function buildClassSelectHtml() {
        let h = '<option value="">(default → analytics)</option>';
        for (let i = 0; i < domainClassNames.length; i++) {
            const c = domainClassNames[i];
            const sel = (c && String(c).toLowerCase() === String(defaultClassName).toLowerCase()) ? ' selected' : '';
            h += '<option value="' + escapeHtml(c) + '"' + sel + '>' + escapeHtml(c) + '</option>';
        }
        return h;
    }

    function escapeHtml(s) {
        if (s === null || s === undefined) return '';
        return String(s)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/"/g, '&quot;');
    }

    function addDomainRow() {
        const tbody = document.getElementById('domainRowsContainer');
        const tr = document.createElement('tr');
        tr.className = 'domain-edit-row';
        const i = domainRowIndex++;
        tr.innerHTML =
            '<td><select name="DomainRows[' + i + '].Enabled" class="form-select form-select-sm" style="min-width:4.5rem" aria-label="Enabled">' +
            '<option value="true" selected>On</option><option value="false">Off</option></select></td>' +
            '<td><input type="text" name="DomainRows[' + i + '].Domain" class="form-control form-control-sm" placeholder="host.example.com"/></td>' +
            '<td><input type="text" name="DomainRows[' + i + '].Ip" class="form-control form-control-sm" placeholder="optional"/></td>' +
            '<td><select name="DomainRows[' + i + '].DomainClass" class="form-select form-select-sm">' + buildClassSelectHtml() + '</select></td>' +
            '<td><select name="DomainRows[' + i + '].ContentKind" class="form-select form-select-sm">' +
            '<option value="javascript" selected>JavaScript</option><option value="html">HTML</option><option value="redirect">Redirect</option></select></td>' +
            '<td><input type="text" name="DomainRows[' + i + '].RedirectUrl" class="form-control form-control-sm" placeholder="if redirect"/></td>' +
            '<td><button type="button" class="btn btn-outline-danger btn-sm" onclick="removeDomainRow(this)">Remove</button></td>';
        tbody.appendChild(tr);
    }

    function removeDomainRow(btn) {
        const tr = btn.closest('tr');
        if (tr) tr.remove();
    }
</script>
</body>
</html>
