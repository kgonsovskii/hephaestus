@model model.CloneModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    @await Html.PartialAsync("_CpBaseHref")
    <title>Clone</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
<header class="container mt-2">
    @await Html.PartialAsync("_LogoutButton")
</header>
<div class="container mt-4 mb-5">
    <p><a href="../">← Control panel</a></p>
    <h1>Clone</h1>
    <p class="text-muted small">
        Remote install runs on the target server over SSH (panel calls DomainHost over HTTP). Log streams in real time. Server IP must be a real remote host, not localhost or loopback.
    </p>

    <ul class="small text-muted mb-3">
        <li>Ubuntu 22+ or Windows Server (or newer desktop Windows)</li>
        <li>1 GB RAM, 1 public IP, 25 GB disk</li>
    </ul>

    <div class="row">
        <div class="col-md-6">
            <label asp-for="CloneServerIp" class="form-label">Server IP</label>
            <input asp-for="CloneServerIp" name="CloneServerIp" value="@Model.CloneServerIp" id="cloneServerIp" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="CloneUser" class="form-label">User</label>
            <input asp-for="CloneUser" name="CloneUser" value="@Model.CloneUser" id="cloneUser" class="form-control" />
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-6">
            <label asp-for="ClonePassword" class="form-label">Password</label>
            <input asp-for="ClonePassword" name="ClonePassword" value="@Model.ClonePassword" id="clonePassword" type="password" class="form-control" />
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-6 d-flex gap-2 flex-wrap align-items-end">
            <button type="button" class="btn btn-primary" id="cloneServerBtn">Start remote install</button>
            <button type="button" class="btn btn-outline-danger" id="cloneStopBtn" disabled>Stop</button>
            <button type="button" class="btn btn-outline-secondary" id="scheduleUpdateBtn">Update DomainHost</button>
        </div>
    </div>

    <div id="cloneResult" class="mt-2"></div>
    <pre id="cloneLog" class="mt-3 p-2 bg-dark text-light small" style="min-height:12rem; max-height:32rem; overflow:auto;"></pre>
</div>

<script>
(function () {
    const clonePostUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize("clone"));
    const cloneStopUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize("clone/stop"));
    const scheduleUpdateUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize("clone/schedule-update"));
    const pathBase = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Context.Request.PathBase.Value ?? ""));

    const CK_SERVER = "newway_clone_server";
    const CK_USER = "newway_clone_user";
    const CK_PASSWORD = "newway_clone_password";

    function cookiePath() {
        const pb = pathBase || "";
        if (!pb || pb === "/") return "/";
        return pb.endsWith("/") ? pb.slice(0, -1) : pb;
    }

    function cookieAttrs() {
        const p = "path=" + cookiePath();
        const age = "max-age=" + (60 * 60 * 24 * 400);
        const same = "SameSite=Lax";
        const sec = location.protocol === "https:" ? "; Secure" : "";
        return p + "; " + age + "; " + same + sec;
    }

    function setCookie(name, value) {
        document.cookie = name + "=" + encodeURIComponent(value || "") + "; " + cookieAttrs();
    }

    function getCookie(name) {
        const prefix = name + "=";
        const parts = document.cookie.split(";");
        for (let i = 0; i < parts.length; i++) {
            const s = parts[i].trim();
            if (s.startsWith(prefix))
                return decodeURIComponent(s.slice(prefix.length));
        }
        return "";
    }

    function hydrateFromCookies() {
        const s = getCookie(CK_SERVER);
        const u = getCookie(CK_USER);
        const pw = getCookie(CK_PASSWORD);
        if (s) document.getElementById("cloneServerIp").value = s;
        if (u) document.getElementById("cloneUser").value = u;
        if (pw) document.getElementById("clonePassword").value = pw;
    }

    function saveCloneFieldsToCookies() {
        setCookie(CK_SERVER, document.getElementById("cloneServerIp").value);
        setCookie(CK_USER, document.getElementById("cloneUser").value);
        setCookie(CK_PASSWORD, document.getElementById("clonePassword").value);
    }

    ["cloneServerIp", "cloneUser", "clonePassword"].forEach(function (id) {
        const el = document.getElementById(id);
        if (el) el.addEventListener("change", saveCloneFieldsToCookies);
    });

    hydrateFromCookies();

    const startBtn = document.getElementById("cloneServerBtn");
    const stopBtn = document.getElementById("cloneStopBtn");
    const scheduleUpdateBtn = document.getElementById("scheduleUpdateBtn");
    let activeWs = null;
    let currentRunId = null;

    function setStopEnabled(on) {
        stopBtn.disabled = !on;
    }

    function appendResult(html) {
        const resultEl = document.getElementById("cloneResult");
        resultEl.insertAdjacentHTML("beforeend", html);
    }

    function closeWs() {
        if (activeWs && activeWs.readyState === WebSocket.OPEN)
            activeWs.close();
        activeWs = null;
    }

    scheduleUpdateBtn.addEventListener("click", async function () {
        const msg = "This will run git pull (discarding local changes to tracked files in the repo on this server) and full reinstall. The panel may be unavailable for up to about 5 minutes. Continue?";
        if (!confirm(msg))
            return;
        const resultEl = document.getElementById("cloneResult");
        try {
            scheduleUpdateBtn.disabled = true;
            const res = await fetch(scheduleUpdateUrl, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                credentials: "same-origin",
                body: "{}"
            });
            const raw = await res.text();
            if (!res.ok) {
                let detail = raw;
                try {
                    const j = JSON.parse(raw);
                    if (j && j.error) detail = j.error;
                } catch (_) { }
                appendResult('<div class="alert alert-danger mt-2">' + detail + "</div>");
                return;
            }
            let serverMsg = "";
            try {
                const j = JSON.parse(raw);
                if (j && j.message) serverMsg = j.message;
            } catch (_) { }
            appendResult('<div class="alert alert-success mt-2"><strong>Update started.</strong> Wait up to about 5 minutes while the server reinstalls. You can monitor <code>/var/log/hephaestus-update.log</code> on the host. ' + (serverMsg ? "<br><span class=\"text-muted small\">" + serverMsg + "</span>" : "") + "</div>");
        } catch (e) {
            console.error(e);
            appendResult('<div class="alert alert-danger mt-2">' + e + "</div>");
        } finally {
            scheduleUpdateBtn.disabled = false;
        }
    });

    stopBtn.addEventListener("click", async function () {
        if (!currentRunId)
            return;
        setStopEnabled(false);
        try {
            const res = await fetch(cloneStopUrl, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                credentials: "same-origin",
                body: JSON.stringify({ runId: currentRunId })
            });
            const data = res.ok ? await res.json() : null;
            if (data && data.stopped)
                appendResult('<div class="alert alert-warning mt-2">Stop requested.</div>');
            else if (!res.ok)
                appendResult('<div class="alert alert-danger mt-2">Stop failed (HTTP ' + res.status + ').</div>');
            else
                appendResult('<div class="alert alert-secondary mt-2">Stop had no effect (run may have finished).</div>');
            currentRunId = null;
            setStopEnabled(false);
        } catch (e) {
            console.error(e);
            appendResult('<div class="alert alert-danger mt-2">' + e + '</div>');
        }
        closeWs();
    });

    startBtn.addEventListener("click", async function () {
        const serverIp = document.getElementById("cloneServerIp").value;
        const user = document.getElementById("cloneUser").value;
        const password = document.getElementById("clonePassword").value;
        const logEl = document.getElementById("cloneLog");
        const resultEl = document.getElementById("cloneResult");
        logEl.textContent = "";
        resultEl.innerHTML = "";
        closeWs();
        currentRunId = null;
        setStopEnabled(false);

        try {
            saveCloneFieldsToCookies();
            const res = await fetch(clonePostUrl, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                credentials: "same-origin",
                body: JSON.stringify({ cloneServerIp: serverIp, cloneUser: user, clonePassword: password })
            });
            if (!res.ok) {
                let msg = "HTTP " + res.status;
                try {
                    const t = await res.text();
                    if (t) {
                        const j = JSON.parse(t);
                        if (j && j.error) msg = j.error;
                    }
                } catch (_) { }
                resultEl.innerHTML = "";
                const errEl = document.createElement("div");
                errEl.className = "alert alert-danger";
                errEl.textContent = msg;
                resultEl.appendChild(errEl);
                return;
            }
            const data = await res.json();
            const runId = data.runId;
            currentRunId = runId;
            setStopEnabled(true);
            resultEl.innerHTML = '<div class="alert alert-info">Queued. Streaming log…</div>';

            const proto = location.protocol === "https:" ? "wss:" : "ws:";
            const pb = (pathBase.endsWith("/") ? pathBase.slice(0, -1) : pathBase) || "";
            const wsPath = (pb ? pb + "/" : "/") + "clone-ws?runId=" + encodeURIComponent(runId);
            const ws = new WebSocket(proto + "//" + location.host + wsPath);
            activeWs = ws;

            ws.onmessage = function (ev) { logEl.textContent += ev.data; logEl.scrollTop = logEl.scrollHeight; };
            ws.onclose = function (ev) {
                appendResult('<div class="alert alert-secondary mt-2">WebSocket closed.</div>');
                activeWs = null;
                if (ev.code === 1000) {
                    currentRunId = null;
                    setStopEnabled(false);
                }
            };
            ws.onerror = function () {
                appendResult('<div class="alert alert-warning mt-2">WebSocket error.</div>');
            };
        } catch (e) {
            console.error(e);
            resultEl.innerHTML = '<div class="alert alert-danger">' + e + '</div>';
            currentRunId = null;
            setStopEnabled(false);
        }
    });
})();
</script>
</body>
</html>
